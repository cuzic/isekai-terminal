{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/cargo-check-on-edit.sh",
            "async": true,
            "asyncRewake": true,
            "rewakeMessage": "cargo build reported warnings/errors after your last edit to a rust-core file:\n",
            "rewakeSummary": "cargo build warnings/errors",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
