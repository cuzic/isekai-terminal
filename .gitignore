# Android build
/build/
/android/build/
/.gradle/
/.kotlin/
*.apk
*.aab

# Rust build
/rust-core/target/
# cargoBuildRustCore Gradle task regenerates this; do not commit prebuilt binaries.
/android/src/main/jniLibs/
# build-ios-xcframework.sh regenerates this; do not commit prebuilt binaries.
/ios/Frameworks/
# Xcode per-user state / SwiftPM local caches (not shared project config).
/ios/App/*.xcodeproj/xcuserdata/
/ios/App/*.xcodeproj/project.xcworkspace/xcuserdata/
/ios/.swiftpm/
/ios/.build/

# IDE
/.idea/
*.iml

# OS
.DS_Store
Thumbs.db

# Claude Code session-local state (agent worktrees, lock files)
/.claude/worktrees/
/.claude/scheduled_tasks.lock
